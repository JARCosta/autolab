# --- Telegram ---
TELEGRAM_NOTIFICATION_TOKEN=
TELEGRAM_LOGS_TOKEN=
TELEGRAM_USER_ID=

# --- Discord (BoostBot) ---
DISCORD_TOKEN=

# --- Ngrok ---
# Set to 0/false/no/off to run webapp without ngrok (LAN/API testing).
WEBAPP_ENABLE_NGROK=1
# Bind host/port for Flask webapp (0.0.0.0 allows LAN access).
WEBAPP_HOST=0.0.0.0
WEBAPP_PORT=5000
NGROK_AUTH_TOKEN=
# Optional: required for some features (e.g. internal endpoints); create in ngrok dashboard.
NGROK_API_KEY=
# Cloud Endpoint public URL (fixed). Use when traffic policy forward-internal targets an internal agent.
NGROK_PUBLIC_URL=
# Internal hostname for the agent; must match forward-internal config.url host (e.g. default.internal).
NGROK_INTERNAL_DOMAIN=

# --- Hardware monitor (optional) ---
# Friendly device label for this server (same .env is loaded in Docker via env_file).
# If unset: Windows COMPUTERNAME, else kernel hostname (in Docker often the container id).
HARDWARE_DEVICE_NAME=
# Shared secret for POST /api/monitor/push. Required for ingest and for the local push client.
HARDWARE_PUSH_TOKEN=
# Seconds per upload cycle; one sample is taken each second, then one POST (default 10 → 10 rows).
HARDWARE_PUSH_INTERVAL=

# --- Faceit ---
FACEIT_API_KEY=
