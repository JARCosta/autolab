# --- Telegram ---
TELEGRAM_NOTIFICATION_TOKEN=
TELEGRAM_LOGS_TOKEN=
TELEGRAM_USER_ID=
# Full HTTPS URL Telegram should POST to (e.g. https://your.domain/webhook behind nginx, Cloudflare Tunnel, etc.).
# If set, ngrok is skipped and the bot still registers its webhook when pyngrok download fails or WEBAPP_ENABLE_NGROK=0.
TELEGRAM_WEBHOOK_PUBLIC_URL=

# --- Discord (BoostBot) ---
DISCORD_TOKEN=

# --- Ngrok ---
# Set to 0/false/no/off to run webapp without ngrok (LAN/API testing).
WEBAPP_ENABLE_NGROK=1
# Show Flask/Werkzeug request lines in logs (GET/POST ... 200).
WEBAPP_SHOW_ACCESS_LOGS=1
# Bind host/port for Flask webapp (0.0.0.0 allows LAN access).
WEBAPP_HOST=0.0.0.0
WEBAPP_PORT=5000
NGROK_AUTH_TOKEN=
# Optional: required for some features (e.g. internal endpoints); create in ngrok dashboard.
NGROK_API_KEY=
# Cloud Endpoint public URL (fixed). Use when traffic policy forward-internal targets an internal agent.
NGROK_PUBLIC_URL=
# Internal hostname for the agent; must match forward-internal config.url host (e.g. default.internal).
NGROK_INTERNAL_DOMAIN=

# --- Hardware monitor (optional) ---
# Friendly device label for this server (same .env is loaded in Docker via env_file).
# If unset: Windows COMPUTERNAME, else kernel hostname (in Docker often the container id).
HARDWARE_DEVICE_NAME=
# Shared secret used by hardware push + pull endpoints.
HARDWARE_TOKEN=
# Nodes self-register on startup. Optional static override (same format as before):
# HARDWARE_PULL_NODES: device→base URL map, e.g. gaming-pc=http://192.168.1.22:8765
HARDWARE_PULL_NODES=
# Legacy: HARDWARE_PULL_CLIENTS (still read if HARDWARE_PULL_NODES is empty)

# --- Faceit ---
FACEIT_API_KEY=
